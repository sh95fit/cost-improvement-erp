// ============================================================
// 원가 정확도 개선 프로젝트 - schema.prisma v5
// Prisma 7 + Next.js 16 (Turbopack) 호환
// v4 → v5: ContainerGroup 폐지 → SubsidiaryMaster(CONTAINER) 흡수
//           MealTemplate 재설계, Supplier에 supplierType 추가
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  @@map("user_status")
}

enum ScopeRole {
  SYSTEM_ADMIN
  COMPANY_ADMIN
  MEMBER
  @@map("scope_role")
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  EXPORT
  @@map("permission_action")
}

enum MaterialType {
  RAW
  OTHER
  @@map("material_type")
}

enum ItemType {
  MATERIAL
  SUBSIDIARY
  @@map("item_type")
}

enum IngredientType {
  MATERIAL
  SEMI_PRODUCT
  @@map("ingredient_type")
}

enum BOMStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  @@map("bom_status")
}

enum MealPlanStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  @@map("meal_plan_status")
}

enum MealSlotType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  @@map("meal_slot_type")
}

enum POStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CANCELLED
  @@map("po_status")
}

enum TransactionType {
  PURCHASE
  CONSUMPTION
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
  DISPOSAL
  @@map("transaction_type")
}

enum TransferStatus {
  REQUESTED
  DRAFT
  CONFIRMED
  RECEIVED
  CANCELLED
  @@map("transfer_status")
}

enum TransferType {
  PUSH
  PULL
  @@map("transfer_type")
}

enum StockTakeStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  @@map("stock_take_status")
}

enum ShippingStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  @@map("shipping_status")
}

enum CookingPlanStatus {
  DRAFT
  CONFIRMED
  COMPLETED
  REPLACED
  @@map("cooking_plan_status")
}

enum ReservationReleaseReason {
  CONSUMED
  AUTO_EXPIRED
  MANUAL_CANCEL
  @@map("reservation_release_reason")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  @@map("notification_channel")
}

enum NotificationLogStatus {
  PENDING
  SENT
  FAILED
  @@map("notification_log_status")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  STATUS_CHANGE
  LOGIN
  OVERRIDE
  @@map("audit_action")
}

enum SnapshotType {
  MONTHLY
  QUARTERLY
  YEARLY
  @@map("snapshot_type")
}

enum CostType {
  ESTIMATED
  ORDER_BASED
  ACTUAL
  @@map("cost_type")
}

enum UnitCategory {
  WEIGHT
  VOLUME
  COUNT
  LENGTH
  @@map("unit_category")
}

enum ProductionLineStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  @@map("production_line_status")
}

enum AutoGenStatus {
  PENDING
  GENERATED
  FAILED
  @@map("auto_gen_status")
}

enum ReceivingNoteStatus {
  DRAFT
  CONFIRMED
  @@map("receiving_note_status")
}

enum ConsumptionStatus {
  DRAFT
  CONFIRMED
  @@map("consumption_status")
}

enum MonthEndStatus {
  DRAFT
  LOCKED
  @@map("month_end_status")
}

enum StockGrade {
  A
  B
  C
  @@map("stock_grade")
}

// ★ 신규 Enum (v5)
enum SubsidiaryType {
  CONTAINER
  ACCESSORY
  CONSUMABLE
  @@map("subsidiary_type")
}

enum ConsumptionMode {
  PER_MEAL_COUNT
  FIXED_QUANTITY
  @@map("consumption_mode")
}

enum SupplierType {
  MATERIAL
  SUBSIDIARY
  @@map("supplier_type")
}


// ============================================================
// MODELS
// ============================================================

// ---- 1. 조직 ----

model Company {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  bizNo     String?  @map("biz_no")
  address   String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users              UserScope[]
  locations          Location[]
  productionLines    ProductionLine[]
  lineups            Lineup[]
  materialMasters    MaterialMaster[]
  subsidiaryMasters  SubsidiaryMaster[]
  unitConversions    UnitConversion[]
  suppliers          Supplier[]
  // ★ 삭제: containerGroups (ContainerGroup 모델 폐지)
  recipes            Recipe[]
  semiProducts       SemiProduct[]
  boms               BOM[]
  recipeBoms         RecipeBOM[]
  mealTemplates      MealTemplate[]
  mealPlanGroups     MealPlanGroup[]
  autoGenLogs        AutoGenLog[]
  purchaseOrders     PurchaseOrder[]
  inventoryLots      InventoryLot[]
  inventoryTransactions InventoryTransaction[]
  inventoryReservations InventoryReservation[]
  inventoryTransfers InventoryTransfer[]
  stockTakes         StockTake[]
  shippingOrders     ShippingOrder[]
  cookingPlans       CookingPlan[]
  costSnapshots      CostSnapshot[]
  monthEndSnapshots  MonthEndSnapshot[]
  monthEndAdjustments MonthEndAdjustment[]
  notificationRules  NotificationRule[]
  notificationLogs   NotificationLog[]
  auditLogs          AuditLog[]
  invitations        Invitation[]
  receivingNotes     ReceivingNote[]
  materialRequirements MaterialRequirement[]
  consumptionItems   ConsumptionItem[]
  costCalculations   CostCalculation[]
  overheadCosts      OverheadCost[]
  unitMasters        UnitMaster[]

  @@map("companies")
}

model Location {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  code      String
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company            Company @relation(fields: [companyId], references: [id])
  productionLines    ProductionLine[]
  lineupLocationMaps LineupLocationMap[]
  inventoryLots      InventoryLot[]
  inventoryTransactions InventoryTransaction[]
  stockTakes         StockTake[]
  transfersFrom      InventoryTransfer[] @relation("TransferFrom")
  transfersTo        InventoryTransfer[] @relation("TransferTo")
  shippingOrders     ShippingOrder[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("locations")
}

model ProductionLine {
  id         String                @id @default(cuid())
  companyId  String                @map("company_id")
  locationId String                @map("location_id")
  name       String
  status     ProductionLineStatus  @default(ACTIVE)
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id])
  location     Location @relation(fields: [locationId], references: [id])
  cookingPlans CookingPlan[]

  @@index([companyId])
  @@index([locationId])
  @@map("production_lines")
}

// ---- 2. 사용자 / 권한 ----

model User {
  id              String     @id @default(cuid())
  providerUserId  String     @unique @map("provider_user_id")
  email           String     @unique
  name            String
  avatarUrl       String?    @map("avatar_url")
  status          UserStatus @default(ACTIVE)
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  scopes                UserScope[]
  auditLogs             AuditLog[]
  monthEndAdjustments   MonthEndAdjustment[]
  invitations           Invitation[]
  createdPurchaseOrders PurchaseOrder[]

  @@map("users")
}

model UserScope {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  companyId       String    @map("company_id")
  role            ScopeRole
  permissionSetId String?   @map("permission_set_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  company       Company        @relation(fields: [companyId], references: [id])
  permissionSet PermissionSet? @relation(fields: [permissionSetId], references: [id])

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_scopes")
}

model PermissionSet {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items      PermissionSetItem[]
  userScopes UserScope[]

  @@map("permission_sets")
}

model PermissionSetItem {
  id              String           @id @default(cuid())
  permissionSetId String           @map("permission_set_id")
  resource        String
  action          PermissionAction
  createdAt       DateTime         @default(now()) @map("created_at")

  permissionSet PermissionSet @relation(fields: [permissionSetId], references: [id])

  @@unique([permissionSetId, resource, action])
  @@index([permissionSetId])
  @@map("permission_set_items")
}

model Invitation {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  email       String
  role        ScopeRole
  invitedById String    @map("invited_by_id")
  token       String    @unique
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  company   Company @relation(fields: [companyId], references: [id])
  invitedBy User    @relation(fields: [invitedById], references: [id])

  @@index([companyId])
  @@index([email])
  @@index([token])
  @@map("invitations")
}


// ---- 3. 식자재 / 부자재 ----

model MaterialMaster {
  id           String       @id @default(cuid())
  companyId    String       @map("company_id")
  name         String
  code         String
  materialType MaterialType @map("material_type")
  unit         String
  unitCategory UnitCategory @map("unit_category")
  minStock     Float?       @map("min_stock")
  maxStock     Float?       @map("max_stock")
  shelfLifeDays Int?        @map("shelf_life_days")
  stockGrade          StockGrade @default(C) @map("stock_grade")
  stockGradeUpdatedAt DateTime?  @map("stock_grade_updated_at")
  defaultSupplierItemId String?      @unique @map("default_supplier_item_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  company               Company @relation(fields: [companyId], references: [id])
  defaultSupplierItem   SupplierItem? @relation("DefaultMaterialSupplierItem", fields: [defaultSupplierItemId], references: [id], onDelete: SetNull)
  supplierItems         SupplierItem[]
  bomItems              BOMItem[]
  unitConversions       UnitConversion[]
  inventoryLots         InventoryLot[]
  inventoryTransactions InventoryTransaction[]
  inventoryReservations InventoryReservation[]
  costSnapshotItems     CostSnapshotItem[]
  materialRequirements  MaterialRequirement[]
  cookingPlanItems      CookingPlanItem[]
  consumptionItems      ConsumptionItem[]
  costCalculationItems  CostCalculationItem[]
  inventoryTransferItems InventoryTransferItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  shippingOrderItems    ShippingOrderItem[]
  recipeIngredients     RecipeIngredient[]
  recipeBomSlotItems    RecipeBOMSlotItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("material_masters")
}

// ★ 변경: subsidiaryType 추가, 용기 슬롯/식단템플릿/레시피BOM 관계 추가
model SubsidiaryMaster {
  id             String         @id @default(cuid())
  companyId      String         @map("company_id")
  name           String
  code           String
  subsidiaryType SubsidiaryType @default(CONSUMABLE) @map("subsidiary_type")
  unit           String
  unitCategory   UnitCategory   @default(COUNT) @map("unit_category")
  stockGrade          StockGrade @default(C) @map("stock_grade")
  stockGradeUpdatedAt DateTime?  @map("stock_grade_updated_at")
  defaultSupplierItemId String?  @unique @map("default_supplier_item_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company              Company @relation(fields: [companyId], references: [id])
  defaultSupplierItem  SupplierItem? @relation("DefaultSubsidiarySupplierItem", fields: [defaultSupplierItemId], references: [id], onDelete: SetNull)
  supplierItems        SupplierItem[]
  mealPlanAccessories  MealPlanAccessory[]
  purchaseOrderItems   PurchaseOrderItem[]
  inventoryLots        InventoryLot[]
  shippingOrderItems   ShippingOrderItem[]
  unitConversions      UnitConversion[]
  // ★ 신규: 용기 슬롯 (subsidiaryType=CONTAINER일 때)
  containerSlots       ContainerSlot[]
  // ★ 신규: 식단 템플릿 용기 연결
  mealTemplateContainers MealTemplateContainer[]
  // ★ 신규: 식단 템플릿 악세서리 연결
  mealTemplateAccessories MealTemplateAccessory[]
  // ★ 신규: 레시피 BOM 슬롯 연결
  recipeBomSlots       RecipeBOMSlot[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, subsidiaryType])
  @@map("subsidiary_masters")
}

// ★ 변경: supplierType 추가
model Supplier {
  id           String       @id @default(cuid())
  companyId    String       @map("company_id")
  name         String
  code         String
  supplierType SupplierType @default(MATERIAL) @map("supplier_type")
  contactName  String?      @map("contact_name")
  contactPhone String?      @map("contact_phone")
  contactEmail String?      @map("contact_email")
  address      String?
  note         String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  company        Company @relation(fields: [companyId], references: [id])
  supplierItems  SupplierItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, supplierType])
  @@map("suppliers")
}

model SupplierItem {
  id                 String   @id @default(cuid())
  supplierId         String   @map("supplier_id")
  itemType           ItemType @map("item_type")
  materialMasterId   String?  @map("material_master_id")
  subsidiaryMasterId String?  @map("subsidiary_master_id")
  supplierItemCode   String?  @map("supplier_item_code")
  productName        String   @map("product_name")
  spec               String?  @map("spec")
  supplyUnit         String   @map("supply_unit")
  supplyUnitQty      Float    @map("supply_unit_qty")
  currentPrice       Float    @map("current_price")
  leadTimeDays       Int      @default(1) @map("lead_time_days")
  moq                Float?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  supplier           Supplier          @relation(fields: [supplierId], references: [id])
  materialMaster     MaterialMaster?   @relation(fields: [materialMasterId], references: [id])
  subsidiaryMaster   SubsidiaryMaster? @relation(fields: [subsidiaryMasterId], references: [id])
  priceHistories     SupplierItemPriceHistory[]
  purchaseOrderItems PurchaseOrderItem[]
  defaultForMaterial    MaterialMaster?    @relation("DefaultMaterialSupplierItem")
  defaultForSubsidiary  SubsidiaryMaster?  @relation("DefaultSubsidiarySupplierItem")

  @@unique([supplierId, itemType, materialMasterId, productName], map: "uq_supplier_material_product")
  @@unique([supplierId, itemType, subsidiaryMasterId, productName], map: "uq_supplier_subsidiary_product")
  @@index([supplierId])
  @@index([materialMasterId])
  @@index([subsidiaryMasterId])
  @@map("supplier_items")
}

model SupplierItemPriceHistory {
  id             String   @id @default(cuid())
  supplierItemId String   @map("supplier_item_id")
  price          Float
  effectiveFrom  DateTime @map("effective_from")
  effectiveTo    DateTime? @map("effective_to")
  createdAt      DateTime @default(now()) @map("created_at")

  supplierItem SupplierItem @relation(fields: [supplierItemId], references: [id])

  @@index([supplierItemId])
  @@map("supplier_item_price_histories")
}

// ---- 4. 용기 슬롯 (ContainerGroup 폐지 → SubsidiaryMaster로 흡수) ----
// ★ 변경: containerGroupId → subsidiaryMasterId

model ContainerSlot {
  id                 String @id @default(cuid())
  subsidiaryMasterId String @map("subsidiary_master_id")
  slotIndex          Int    @map("slot_index")
  label              String
  volumeMl           Float? @map("volume_ml")

  subsidiaryMaster SubsidiaryMaster @relation(fields: [subsidiaryMasterId], references: [id])

  @@unique([subsidiaryMasterId, slotIndex])
  @@index([subsidiaryMasterId])
  @@map("container_slots")
}

// ★ 삭제: ContainerGroup 모델 전체 제거
// ★ 삭제: ContainerAccessory 모델 전체 제거

// ---- 5. 레시피 / BOM ----

model Recipe {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  name        String
  code        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  company          Company            @relation(fields: [companyId], references: [id])
  ingredients      RecipeIngredient[]
  recipeBoms       RecipeBOM[]
  mealPlanSlots    MealPlanSlot[]
  cookingPlanSlots CookingPlanSlot[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("recipes")
}

model RecipeIngredient {
  id               String         @id @default(cuid())
  recipeId         String         @map("recipe_id")
  ingredientType   IngredientType @map("ingredient_type")
  materialMasterId String?        @map("material_master_id")
  semiProductId    String?        @map("semi_product_id")
  sortOrder        Int            @default(0) @map("sort_order")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  recipe         Recipe          @relation(fields: [recipeId], references: [id])
  materialMaster MaterialMaster? @relation(fields: [materialMasterId], references: [id])
  semiProduct    SemiProduct?    @relation(fields: [semiProductId], references: [id])

  @@index([recipeId])
  @@index([materialMasterId])
  @@index([semiProductId])
  @@map("recipe_ingredients")
}

model RecipeBOM {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  recipeId    String    @map("recipe_id")
  version     Int       @default(1)
  status      BOMStatus @default(DRAFT)
  baseWeightG Float     @map("base_weight_g")
  activatedAt DateTime? @map("activated_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  company Company       @relation(fields: [companyId], references: [id])
  recipe  Recipe        @relation(fields: [recipeId], references: [id])
  slots   RecipeBOMSlot[]

  @@index([companyId])
  @@index([recipeId])
  @@map("recipe_boms")
}

// ★ 변경: containerGroupId → subsidiaryMasterId
model RecipeBOMSlot {
  id                 String   @id @default(cuid())
  recipeBomId        String   @map("recipe_bom_id")
  subsidiaryMasterId String   @map("subsidiary_master_id")
  slotIndex          Int      @map("slot_index")
  totalWeightG       Float    @map("total_weight_g")
  note               String?
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")

  recipeBom        RecipeBOM          @relation(fields: [recipeBomId], references: [id])
  subsidiaryMaster SubsidiaryMaster   @relation(fields: [subsidiaryMasterId], references: [id])
  items            RecipeBOMSlotItem[]

  @@unique([recipeBomId, subsidiaryMasterId, slotIndex])
  @@index([recipeBomId])
  @@index([subsidiaryMasterId])
  @@map("recipe_bom_slots")
}

model RecipeBOMSlotItem {
  id               String         @id @default(cuid())
  recipeBomSlotId  String         @map("recipe_bom_slot_id")
  ingredientType   IngredientType @map("ingredient_type")
  materialMasterId String?        @map("material_master_id")
  semiProductId    String?        @map("semi_product_id")
  weightG          Float          @map("weight_g")
  unit             String         @default("g")
  sortOrder        Int            @default(0) @map("sort_order")
  createdAt        DateTime       @default(now()) @map("created_at")

  recipeBomSlot  RecipeBOMSlot   @relation(fields: [recipeBomSlotId], references: [id])
  materialMaster MaterialMaster? @relation(fields: [materialMasterId], references: [id])
  semiProduct    SemiProduct?    @relation(fields: [semiProductId], references: [id])

  @@index([recipeBomSlotId])
  @@index([materialMasterId])
  @@index([semiProductId])
  @@map("recipe_bom_slot_items")
}

model SemiProduct {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  code      String
  unit      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company            Company            @relation(fields: [companyId], references: [id])
  boms               BOM[]
  recipeIngredients  RecipeIngredient[]
  recipeBomSlotItems RecipeBOMSlotItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("semi_products")
}

model BOM {
  id            String    @id @default(cuid())
  companyId     String    @map("company_id")
  semiProductId String    @map("semi_product_id")
  version       Int       @default(1)
  status        BOMStatus @default(DRAFT)
  baseQuantity  Float     @default(1) @map("base_quantity")
  baseUnit      String    @default("kg") @map("base_unit")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  company     Company     @relation(fields: [companyId], references: [id])
  semiProduct SemiProduct @relation(fields: [semiProductId], references: [id])
  items       BOMItem[]

  @@index([companyId])
  @@index([semiProductId])
  @@map("boms")
}

model BOMItem {
  id               String   @id @default(cuid())
  bomId            String   @map("bom_id")
  materialMasterId String   @map("material_master_id")
  quantity         Float
  unit             String
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  bom            BOM             @relation(fields: [bomId], references: [id])
  materialMaster MaterialMaster  @relation(fields: [materialMasterId], references: [id])

  @@index([bomId])
  @@index([materialMasterId])
  @@map("bom_items")
}

model UnitConversion {
  id                 String       @id @default(cuid())
  companyId          String       @map("company_id")
  materialMasterId   String?      @map("material_master_id")
  subsidiaryMasterId String?      @map("subsidiary_master_id")
  fromUnit           String       @map("from_unit")
  toUnit             String       @map("to_unit")
  factor             Float
  unitCategory       UnitCategory @map("unit_category")
  createdAt          DateTime     @default(now()) @map("created_at")

  company          Company          @relation(fields: [companyId], references: [id])
  materialMaster   MaterialMaster?  @relation(fields: [materialMasterId], references: [id])
  subsidiaryMaster SubsidiaryMaster? @relation(fields: [subsidiaryMasterId], references: [id])

  @@unique([companyId, materialMasterId, subsidiaryMasterId, fromUnit, toUnit])
  @@index([companyId])
  @@index([materialMasterId])
  @@index([subsidiaryMasterId])
  @@map("unit_conversions")
}

model UnitMaster {
  id           String       @id @default(cuid())
  companyId    String       @map("company_id")
  itemType     ItemType     @map("item_type")
  unitCategory UnitCategory @map("unit_category")
  code         String
  name         String
  isSystem     Boolean      @default(false) @map("is_system")
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, itemType, code])
  @@index([companyId, itemType, unitCategory])
  @@map("unit_masters")
}

// ---- 6. 식단 템플릿 ---- // ★ 전면 재설계

model MealTemplate {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company                 @relation(fields: [companyId], references: [id])
  containers  MealTemplateContainer[]
  accessories MealTemplateAccessory[]

  // ★ 삭제: containerGroupId, slots (MealTemplateSlot 모델 폐지)
  @@index([companyId])
  @@map("meal_templates")
}

// ★ 신규: 식단 템플릿 ↔ 용기(SubsidiaryMaster CONTAINER) 연결 (1:N)
model MealTemplateContainer {
  id                 String @id @default(cuid())
  mealTemplateId     String @map("meal_template_id")
  subsidiaryMasterId String @map("subsidiary_master_id")
  sortOrder          Int    @default(0) @map("sort_order")

  mealTemplate     MealTemplate     @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  subsidiaryMaster SubsidiaryMaster @relation(fields: [subsidiaryMasterId], references: [id])

  @@unique([mealTemplateId, subsidiaryMasterId])
  @@index([mealTemplateId])
  @@index([subsidiaryMasterId])
  @@map("meal_template_containers")
}

// ★ 변경: 부자재 참조 + 소비모드 추가 (이름 문자열 → SubsidiaryMaster FK)
model MealTemplateAccessory {
  id                 String          @id @default(cuid())
  mealTemplateId     String          @map("meal_template_id")
  subsidiaryMasterId String          @map("subsidiary_master_id")
  consumptionType    ConsumptionMode @default(PER_MEAL_COUNT) @map("consumption_type")
  fixedQuantity      Float?          @map("fixed_quantity")
  isRequired         Boolean         @default(false) @map("is_required")

  mealTemplate     MealTemplate     @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  subsidiaryMaster SubsidiaryMaster @relation(fields: [subsidiaryMasterId], references: [id])

  @@unique([mealTemplateId, subsidiaryMasterId])
  @@index([mealTemplateId])
  @@index([subsidiaryMasterId])
  @@map("meal_template_accessories")
}

// ★ 삭제: MealTemplateSlot 모델 전체 제거

// ---- 7. 식단 계획 ----

model MealPlanGroup {
  id        String         @id @default(cuid())
  companyId String         @map("company_id")
  lineupId  String         @map("lineup_id")
  planDate  DateTime       @map("plan_date") @db.Date
  status    MealPlanStatus @default(DRAFT)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  company              Company              @relation(fields: [companyId], references: [id])
  lineup               Lineup               @relation(fields: [lineupId], references: [id])
  mealPlans            MealPlan[]
  mealCounts           MealCount[]
  materialRequirements MaterialRequirement[]
  purchaseOrders       PurchaseOrder[]
  shippingOrders       ShippingOrder[]

  @@unique([companyId, lineupId, planDate])
  @@index([companyId])
  @@index([lineupId])
  @@index([planDate])
  @@map("meal_plan_groups")
}

model MealPlan {
  id              String       @id @default(cuid())
  mealPlanGroupId String       @map("meal_plan_group_id")
  slotType        MealSlotType @map("slot_type")
  mealTemplateId  String?      @map("meal_template_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  mealPlanGroup MealPlanGroup     @relation(fields: [mealPlanGroupId], references: [id])
  slots         MealPlanSlot[]
  accessories   MealPlanAccessory[]

  @@unique([mealPlanGroupId, slotType])
  @@index([mealPlanGroupId])
  @@map("meal_plans")
}

model MealPlanSlot {
  id          String   @id @default(cuid())
  mealPlanId  String   @map("meal_plan_id")
  slotIndex   Int      @map("slot_index")
  recipeId    String?  @map("recipe_id")
  recipeBomId String?  @map("recipe_bom_id")
  quantity    Int      @default(0)
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  mealPlan  MealPlan   @relation(fields: [mealPlanId], references: [id])
  recipe    Recipe?    @relation(fields: [recipeId], references: [id])

  @@unique([mealPlanId, slotIndex])
  @@index([mealPlanId])
  @@index([recipeId])
  @@map("meal_plan_slots")
}

model MealCount {
  id              String       @id @default(cuid())
  mealPlanGroupId String       @map("meal_plan_group_id")
  slotType        MealSlotType @map("slot_type")
  estimatedCount  Int?         @map("estimated_count")
  finalCount      Int?         @map("final_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  mealPlanGroup MealPlanGroup @relation(fields: [mealPlanGroupId], references: [id])

  @@unique([mealPlanGroupId, slotType])
  @@index([mealPlanGroupId])
  @@map("meal_counts")
}

model MealPlanAccessory {
  id                 String @id @default(cuid())
  mealPlanId         String @map("meal_plan_id")
  subsidiaryMasterId String @map("subsidiary_master_id")
  quantity           Float
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  mealPlan         MealPlan         @relation(fields: [mealPlanId], references: [id])
  subsidiaryMaster SubsidiaryMaster @relation(fields: [subsidiaryMasterId], references: [id])

  @@index([mealPlanId])
  @@index([subsidiaryMasterId])
  @@map("meal_plan_accessories")
}


// ---- 8. 라인업 ----

model Lineup {
  id        String    @id @default(cuid())
  companyId String    @map("company_id")
  name      String
  code      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company        Company            @relation(fields: [companyId], references: [id])
  locationMaps   LineupLocationMap[]
  mealPlanGroups MealPlanGroup[]
  shippingOrders ShippingOrder[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("lineups")
}

model LineupLocationMap {
  id         String   @id @default(cuid())
  lineupId   String   @map("lineup_id")
  locationId String   @map("location_id")
  createdAt  DateTime @default(now()) @map("created_at")

  lineup   Lineup   @relation(fields: [lineupId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([lineupId, locationId])
  @@index([lineupId])
  @@index([locationId])
  @@map("lineup_location_maps")
}

// ---- 9. 자동 생성 ----

model AutoGenLog {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
