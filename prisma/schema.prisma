  note            String?
  bomSnapshotJson Json?    @map("bom_snapshot_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  cookingPlan CookingPlan @relation(fields: [cookingPlanId], references: [id])
  recipe      Recipe?     @relation(fields: [recipeId], references: [id])

  @@unique([cookingPlanId, slotIndex])
  @@index([cookingPlanId])
  @@index([recipeId])
  @@map("cooking_plan_slots")
}

// ---- 14. 원가 ----

model CostSnapshot {
  id           String       @id @default(cuid())
  companyId    String       @map("company_id")
  snapshotType SnapshotType @map("snapshot_type")
  periodStart  DateTime     @map("period_start") @db.Date
  periodEnd    DateTime     @map("period_end") @db.Date
  totalCost    Float        @map("total_cost")
  createdAt    DateTime     @default(now()) @map("created_at")

  company Company          @relation(fields: [companyId], references: [id])
  items   CostSnapshotItem[]

  @@index([companyId])
  @@index([periodStart])
  @@map("cost_snapshots")
}

model CostSnapshotItem {
  id               String   @id @default(cuid())
  costSnapshotId   String   @map("cost_snapshot_id")
  materialMasterId String   @map("material_master_id")
  avgUnitPrice     Float    @map("avg_unit_price")
  totalQty         Float    @map("total_qty")
  totalCost        Float    @map("total_cost")
  createdAt        DateTime @default(now()) @map("created_at")

  costSnapshot   CostSnapshot   @relation(fields: [costSnapshotId], references: [id])
  materialMaster MaterialMaster @relation(fields: [materialMasterId], references: [id])

  @@index([costSnapshotId])
  @@map("cost_snapshot_items")
}

model CostCalculation {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  costType      CostType @map("cost_type")
  referenceType String   @map("reference_type")
  referenceId   String   @map("reference_id")
  totalCost     Float    @map("total_cost")
  costPerUnit   Float?   @map("cost_per_unit")
  calculatedAt  DateTime @default(now()) @map("calculated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  company Company              @relation(fields: [companyId], references: [id])
  items   CostCalculationItem[]

  @@index([companyId])
  @@index([referenceType, referenceId])
  @@map("cost_calculations")
}

model CostCalculationItem {
  id                String   @id @default(cuid())
  costCalculationId String   @map("cost_calculation_id")
  materialMasterId  String   @map("material_master_id")
  quantity          Float
  unitPrice         Float    @map("unit_price")
  totalPrice        Float    @map("total_price")
  createdAt         DateTime @default(now()) @map("created_at")

  costCalculation CostCalculation @relation(fields: [costCalculationId], references: [id])
  materialMaster  MaterialMaster  @relation(fields: [materialMasterId], references: [id])

  @@index([costCalculationId])
  @@map("cost_calculation_items")
}

model OverheadCost {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  category  String
  name      String
  amount    Float
  month     DateTime @db.Date
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([month])
  @@map("overhead_costs")
}


// ---- 15. 월말 마감 ----

model MonthEndSnapshot {
  id             String        @id @default(cuid())
  companyId      String        @map("company_id")
  closingMonth   DateTime      @map("closing_month") @db.Date
  status         MonthEndStatus @default(DRAFT)
  snapshotData   Json          @map("snapshot_data")
  lockedAt       DateTime?     @map("locked_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  company     Company              @relation(fields: [companyId], references: [id])
  adjustments MonthEndAdjustment[]

  @@unique([companyId, closingMonth])
  @@index([companyId])
  @@map("month_end_snapshots")
}

model MonthEndAdjustment {
  id                  String   @id @default(cuid())
  companyId           String   @map("company_id")
  monthEndSnapshotId  String   @map("month_end_snapshot_id")
  adjustmentNumber    String   @map("adjustment_number")
  reason              String
  adjustedById        String   @map("adjusted_by_id")
  beforeSnapshot      Json     @map("before_snapshot")
  afterSnapshot       Json     @map("after_snapshot")
  createdAt           DateTime @default(now()) @map("created_at")

  company          Company          @relation(fields: [companyId], references: [id])
  monthEndSnapshot MonthEndSnapshot @relation(fields: [monthEndSnapshotId], references: [id])
  adjustedBy       User             @relation(fields: [adjustedById], references: [id])
  items            MonthEndAdjustmentItem[]

  @@index([companyId])
  @@index([monthEndSnapshotId])
  @@map("month_end_adjustments")
}

model MonthEndAdjustmentItem {
  id           String   @id @default(cuid())
  adjustmentId String   @map("adjustment_id")
  materialId   String   @map("material_id")
  itemName     String   @map("item_name")
  field        String
  beforeValue  String   @map("before_value")
  afterValue   String   @map("after_value")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")

  adjustment MonthEndAdjustment @relation(fields: [adjustmentId], references: [id])

  @@index([adjustmentId])
  @@map("month_end_adjustment_items")
}


// ---- 16. 알림 ----

model NotificationTagDef {
  id          String   @id @default(cuid())
  tagKey      String   @unique @map("tag_key")
  label       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notification_tag_defs")
}

model NotificationRule {
  id         String              @id @default(cuid())
  companyId  String              @map("company_id")
  eventType  String              @map("event_type")
  channel    NotificationChannel
  templateId String              @map("template_id")
  isActive   Boolean             @default(true) @map("is_active")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  company  Company              @relation(fields: [companyId], references: [id])
  template NotificationTemplate @relation(fields: [templateId], references: [id])

  @@index([companyId])
  @@map("notification_rules")
}

model NotificationTemplate {
  id           String              @id @default(cuid())
  name         String
  subject      String?
  bodyTemplate String              @map("body_template")
  channel      NotificationChannel
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  rules NotificationRule[]

  @@map("notification_templates")
}

model NotificationLog {
  id          String                @id @default(cuid())
  companyId   String                @map("company_id")
  recipientId String                @map("recipient_id")
  channel     NotificationChannel
  subject     String?
  body        String
  status      NotificationLogStatus @default(PENDING)
  sentAt      DateTime?             @map("sent_at")
  errorMsg    String?               @map("error_msg")
  createdAt   DateTime              @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([recipientId])
  @@map("notification_logs")
}


// ---- 17. 감사 로그 ----

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String?     @map("company_id")
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?     @map("ip_address")
  createdAt  DateTime    @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
