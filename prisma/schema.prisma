  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  company  Company       @relation(fields: [companyId], references: [id])
  location Location      @relation(fields: [locationId], references: [id])
  items    StockTakeItem[]

  @@index([companyId])
  @@index([locationId])
  @@map("stock_takes")
}

model StockTakeItem {
  id               String   @id @default(cuid())
  stockTakeId      String   @map("stock_take_id")
  materialMasterId String   @map("material_master_id")
  systemQty        Float    @map("system_qty")
  actualQty        Float    @map("actual_qty")
  difference       Float
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")

  stockTake StockTake @relation(fields: [stockTakeId], references: [id])

  @@index([stockTakeId])
  @@map("stock_take_items")
}

// ---- 12. 출하 / 소비 ----

model ShippingOrder {
