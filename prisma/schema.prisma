}


// ---- 10. 발주 ----

model PurchaseOrder {
  id               String    @id @default(cuid())
  companyId        String    @map("company_id")
  supplierId       String    @map("supplier_id")
  orderNumber      String    @unique @map("order_number")
  status           POStatus  @default(DRAFT)
  orderDate        DateTime  @map("order_date") @db.Date
  deliveryDate     DateTime? @map("delivery_date") @db.Date
  totalAmount      Float?    @map("total_amount")
  note             String?
  isManual         Boolean   @default(false) @map("is_manual")
  mealPlanGroupId  String?   @map("meal_plan_group_id")
  createdByUserId  String?   @map("created_by_user_id")
  approvedAt       DateTime? @map("approved_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  company        Company        @relation(fields: [companyId], references: [id])
  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  mealPlanGroup  MealPlanGroup? @relation(fields: [mealPlanGroupId], references: [id])
  createdByUser  User?          @relation(fields: [createdByUserId], references: [id])
  items          PurchaseOrderItem[]
  receivingNotes ReceivingNote[]

  @@index([companyId])
  @@index([supplierId])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                 String   @id @default(cuid())
  purchaseOrderId    String   @map("purchase_order_id")
  supplierItemId     String   @map("supplier_item_id")
  itemType           ItemType @default(MATERIAL) @map("item_type")
  materialMasterId   String?  @map("material_master_id")
  subsidiaryMasterId String?  @map("subsidiary_master_id")
  systemQuantity     Float?   @map("system_quantity")
  adjustedQuantity   Float?   @map("adjusted_quantity")
  adjustmentReason   String?  @map("adjustment_reason")
  sourceType         String?  @map("source_type")
  quantity           Float
  unitPrice          Float    @map("unit_price")
  totalPrice         Float    @map("total_price")
  receivedQty        Float    @default(0) @map("received_qty")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  purchaseOrder      PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  supplierItem       SupplierItem      @relation(fields: [supplierItemId], references: [id])
  materialMaster     MaterialMaster?   @relation(fields: [materialMasterId], references: [id])
  subsidiaryMaster   SubsidiaryMaster? @relation(fields: [subsidiaryMasterId], references: [id])
  receivingNoteItems ReceivingNoteItem[]

  @@index([purchaseOrderId])
  @@index([supplierItemId])
  @@map("purchase_order_items")
}

model ReceivingNote {
  id              String              @id @default(cuid())
  companyId       String              @map("company_id")
  purchaseOrderId String              @map("purchase_order_id")
  receiveNumber   String              @unique @map("receive_number")
  status          ReceivingNoteStatus @default(DRAFT)
  receivedDate    DateTime            @map("received_date") @db.Date
  note            String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  company       Company       @relation(fields: [companyId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  items         ReceivingNoteItem[]

  @@index([companyId])
  @@index([purchaseOrderId])
  @@map("receiving_notes")
}

model ReceivingNoteItem {
  id                  String   @id @default(cuid())
  receivingNoteId     String   @map("receiving_note_id")
  purchaseOrderItemId String   @map("purchase_order_item_id")
  receivedQty         Float    @map("received_qty")
  unitPrice           Float    @map("unit_price")
  note                String?
  createdAt           DateTime @default(now()) @map("created_at")

  receivingNote     ReceivingNote     @relation(fields: [receivingNoteId], references: [id])
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])

  @@index([receivingNoteId])
  @@index([purchaseOrderItemId])
  @@map("receiving_note_items")
}


// ---- 11. 재고 ----

model InventoryLot {
  id                  String    @id @default(cuid())
  companyId           String    @map("company_id")
  locationId          String    @map("location_id")
  materialMasterId    String    @map("material_master_id")
  itemType            ItemType  @default(MATERIAL) @map("item_type")
  subsidiaryMasterId  String?   @map("subsidiary_master_id")
  receivingNoteItemId String?   @map("receiving_note_item_id")
  lotNumber           String    @map("lot_number")
  initialQty          Float     @map("initial_qty")
  remainingQty        Float     @map("remaining_qty")
  unitPrice           Float     @map("unit_price")
  expirationDate      DateTime? @map("expiration_date") @db.Date
  receivedAt          DateTime  @default(now()) @map("received_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  company              Company              @relation(fields: [companyId], references: [id])
  location             Location             @relation(fields: [locationId], references: [id])
  materialMaster       MaterialMaster       @relation(fields: [materialMasterId], references: [id])
  subsidiaryMaster     SubsidiaryMaster?    @relation(fields: [subsidiaryMasterId], references: [id])
  transactions         InventoryTransaction[]
  reservations         InventoryReservation[]
  consumptionLotDetails ConsumptionLotDetail[]

  @@index([companyId])
  @@index([locationId])
  @@index([materialMasterId])
  @@index([lotNumber])
  @@map("inventory_lots")
}

model InventoryTransaction {
  id               String          @id @default(cuid())
  companyId        String          @map("company_id")
  locationId       String          @map("location_id")
  materialMasterId String          @map("material_master_id")
  inventoryLotId   String?         @map("inventory_lot_id")
  transactionType  TransactionType @map("transaction_type")
  quantity         Float
  unitPrice        Float?          @map("unit_price")
  referenceType    String?         @map("reference_type")
  referenceId      String?         @map("reference_id")
  note             String?
  transactionDate  DateTime        @default(now()) @map("transaction_date")
  createdAt        DateTime        @default(now()) @map("created_at")

  company        Company        @relation(fields: [companyId], references: [id])
  location       Location       @relation(fields: [locationId], references: [id])
  materialMaster MaterialMaster @relation(fields: [materialMasterId], references: [id])
  inventoryLot   InventoryLot?  @relation(fields: [inventoryLotId], references: [id])

  @@index([companyId])
  @@index([locationId])
  @@index([materialMasterId])
  @@index([inventoryLotId])
  @@index([transactionDate])
  @@map("inventory_transactions")
}

model InventoryReservation {
  id               String                   @id @default(cuid())
  companyId        String                   @map("company_id")
  inventoryLotId   String                   @map("inventory_lot_id")
  materialMasterId String                   @map("material_master_id")
  referenceType    String                   @map("reference_type")
  referenceId      String                   @map("reference_id")
  quantity         Float
  useDate          DateTime                 @map("use_date") @db.Date
  reservedAt       DateTime                 @default(now()) @map("reserved_at")
  releasedAt       DateTime?                @map("released_at")
  releaseReason    ReservationReleaseReason? @map("release_reason")
  createdAt        DateTime                 @default(now()) @map("created_at")

  company        Company        @relation(fields: [companyId], references: [id])
  inventoryLot   InventoryLot   @relation(fields: [inventoryLotId], references: [id])
  materialMaster MaterialMaster @relation(fields: [materialMasterId], references: [id])

  @@index([companyId])
  @@index([inventoryLotId])
  @@index([materialMasterId])
  @@index([useDate])
  @@map("inventory_reservations")
}

model InventoryTransfer {
  id             String         @id @default(cuid())
  companyId      String         @map("company_id")
  fromLocationId String         @map("from_location_id")
  toLocationId   String         @map("to_location_id")
  transferType   TransferType   @map("transfer_type")
  status         TransferStatus @default(DRAFT)
  requestedAt    DateTime       @default(now()) @map("requested_at")
  confirmedAt    DateTime?      @map("confirmed_at")
  receivedAt     DateTime?      @map("received_at")
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  company      Company               @relation(fields: [companyId], references: [id])
  fromLocation Location              @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation   Location              @relation("TransferTo", fields: [toLocationId], references: [id])
  items        InventoryTransferItem[]

  @@index([companyId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("inventory_transfers")
}

model InventoryTransferItem {
  id                  String   @id @default(cuid())
  inventoryTransferId String   @map("inventory_transfer_id")
  materialMasterId    String   @map("material_master_id")
  quantity            Float
  note                String?
  createdAt           DateTime @default(now()) @map("created_at")

  inventoryTransfer InventoryTransfer @relation(fields: [inventoryTransferId], references: [id])
  materialMaster    MaterialMaster    @relation(fields: [materialMasterId], references: [id])

  @@index([inventoryTransferId])
  @@map("inventory_transfer_items")
}

model StockTake {
  id         String          @id @default(cuid())
  companyId  String          @map("company_id")
  locationId String          @map("location_id")
  status     StockTakeStatus @default(DRAFT)
  takeDate   DateTime        @map("take_date") @db.Date
